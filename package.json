{
  "name": "orcamento-api",
  "version": "1.0.0",
  "description": "API Express para geração de orçamentos com React SSR e Tailwind CSS v4",
  "main": "index.js",
  "scripts": {
    "start": "babel-node index.js",
    "dev": "nodemon --exec babel-node src/index.js",
    "tailwind:build": "npx tailwindcss -i ./public/styles.css -o ./public/output.css",
    "tailwind:watch": "npx tailwindcss -i ./public/styles.css -o ./public/output.css --watch",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [
    "express",
    "react",
    "ssr",
    "report"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@babel/core": "^7.29.0",
    "@babel/node": "^7.24.5",
    "@babel/preset-env": "^7.24.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/register": "^7.28.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "lucide-react": "^1.8.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "tailwindcss": "^3.4.19"
  },
  "nodemonConfig": {
    "ext": "js,jsx"
  }
}
